# Required in production
PUBLIC_BASE_URL=https://project.vercel.app
SINGLE_USER_EMAIL=owner@example.com
AUTH_REQUIRED=true
COOKIE_SECURE=true
ADMIN_API_KEY=replace-with-a-long-random-value
POSTGRES_DB=video_analizier
POSTGRES_USER=video_analizier
POSTGRES_PASSWORD=replace-with-a-long-random-value
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Shared OVH VPS: keep Caddy behind the existing host nginx.
CADDY_HTTP_BIND=127.0.0.1:8082
CADDY_HTTPS_BIND=127.0.0.1:8443

# One server-side LLM configuration shared by every user
LLM_PROVIDER=openrouter
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Preferred OpenAI-compatible provider for the private test deployment
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
# Legacy compatibility only: use OPENROUTER_* for new deployments
CURSOR_API_KEY=
CURSOR_BASE_URL=https://api.openai.com/v1
CURSOR_MODEL=gpt-4o-mini

WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=pl
YTDLP_COOKIES=
YTDLP_PROXY=
YTDLP_MAX_RETRIES=3
YTDLP_RETRY_BACKOFF_SECONDS=2

MAX_VIDEO_DURATION_SECONDS=3600
MAX_AUDIO_DURATION_SECONDS=7200
DAILY_SOURCE_LIMIT=20
DAILY_QUESTION_LIMIT=30
GLOBAL_DAILY_LLM_LIMIT=1000
MAX_UPLOAD_BYTES=104857600
MAX_TEXT_BYTES=1048576
JOB_MAX_ATTEMPTS=3
JOB_STALE_SECONDS=1800
JOB_RETRY_BASE_SECONDS=5
WORKER_POLL_SECONDS=3
MAX_SUMMARY_CHUNKS=6
ALLOWED_ORIGINS=

# Required in production
PUBLIC_BASE_URL=https://app.example.com
AUTH_REQUIRED=true
COOKIE_SECURE=true
ADMIN_API_KEY=replace-with-a-long-random-value
POSTGRES_DB=video_analizier
POSTGRES_USER=video_analizier
POSTGRES_PASSWORD=replace-with-a-long-random-value
RESEND_API_KEY=
RESEND_FROM_EMAIL=video-analizier@example.com
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# One server-side LLM configuration shared by every user
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514
CURSOR_API_KEY=
CURSOR_BASE_URL=https://api.openai.com/v1
CURSOR_MODEL=gpt-4o-mini

WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=pl
YTDLP_COOKIES=
YTDLP_PROXY=
YTDLP_MAX_RETRIES=3
YTDLP_RETRY_BACKOFF_SECONDS=2

MAX_VIDEO_DURATION_SECONDS=3600
MAX_AUDIO_DURATION_SECONDS=7200
DAILY_SOURCE_LIMIT=3
DAILY_QUESTION_LIMIT=10
GLOBAL_DAILY_LLM_LIMIT=1000
MAX_UPLOAD_BYTES=104857600
MAX_TEXT_BYTES=1048576
JOB_MAX_ATTEMPTS=3
JOB_STALE_SECONDS=1800
JOB_RETRY_BASE_SECONDS=5
WORKER_POLL_SECONDS=3
MAX_SUMMARY_CHUNKS=6
ALLOWED_ORIGINS=

# OpenAI-compatible LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Whisper ASR
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=pl

# Optional Netscape cookies file for YouTube bot checks
YTDLP_COOKIES=

# App storage
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/app.db
MEDIA_DIR=./data/media

# Server
HOST=0.0.0.0
PORT=8000
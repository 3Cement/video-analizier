# LLM provider: openai | anthropic | cursor
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Cursor / OpenAI-compatible BYOK (np. klucz i endpoint jak w Cursor → Models)
CURSOR_API_KEY=
CURSOR_BASE_URL=https://api.openai.com/v1
CURSOR_MODEL=gpt-4o-mini

# Whisper ASR
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=pl

# Optional Netscape cookies file for YouTube bot checks
YTDLP_COOKIES=
# Optional proxy for YouTube downloads on blocked datacenter IPs
YTDLP_PROXY=
YTDLP_MAX_RETRIES=3
YTDLP_RETRY_BACKOFF_SECONDS=2

# Optional API key for write/read protection (leave empty for open access)
API_KEY=
# Max YouTube duration in seconds (0 = unlimited)
MAX_VIDEO_DURATION_SECONDS=7200
# Max new sources per user per 24h (0 = unlimited)
DAILY_SOURCE_LIMIT=50
# When true, API only enqueues jobs; run `python -m app.worker` separately
WORKER_MODE=false
WORKER_POLL_SECONDS=3

# App storage
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/app.db
MEDIA_DIR=./data/media

# Server
HOST=0.0.0.0
PORT=8000